# AI 防詐盾牌 - 競賽封版環境變數範例

# competition：適合比賽展示 / 預設啟用 token 權限，但允許 Firebase 未連線時啟動
# production：正式上線 / 必須設定 ALLOWED_ORIGINS、Firebase 與 token secret
AI_SHIELD_ENV=competition

# 後端短效 token 簽章密鑰；正式部署務必設定，請自行換成高強度亂數
AI_SHIELD_TOKEN_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=7200
REQUIRE_ACCESS_TOKEN=true
REQUIRE_GUARDIAN_FOR_CLEAR_ALERTS=true
REQUIRE_EXTENSION_SECRET=false
ALLOW_ANONYMOUS_INSTALL=false

# CORS / Socket.IO 來源
# Chrome Extension 正式 ID 出來後，請把 chrome-extension://你的ExtensionID 加進來
ALLOWED_ORIGINS=chrome-extension://你的ExtensionID,https://ai-anti-scam.onrender.com,http://127.0.0.1:5500
STRICT_SOCKET_AUTH=true

# Firebase
FIREBASE_DATABASE_URL=https://你的firebase-default-rtdb.asia-southeast1.firebasedatabase.app
# 二選一：
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# FIREBASE_CREDENTIALS_BASE64=base64後的serviceAccountKey.json
# FIREBASE_KEY_PATH=serviceAccountKey.json

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://你的-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=你的AzureOpenAIKey
AZURE_API_VERSION=2025-01-01-preview
AZURE_MODEL_NAME=gpt-4o-mini
AZURE_OPENAI_TIMEOUT_SEC=8
AZURE_OPENAI_STREAM_TIMEOUT_SEC=12

# LINE 推播，可選
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=
ADMIN_LINE_ID=

# Rate limit 正式部署建議 Redis；competition 可先用 memory://
RATELIMIT_STORAGE_URI=memory://
DEFAULT_RATE_LIMITS=5000 per day,1000 per hour

# 除錯
DEBUG_ERRORS=false
FLASK_DEBUG=false

# 測試期間請關閉 LINE 推播，避免消耗次數
LINE_PUSH_ENABLED=true
LINE_PUSH_DRY_RUN=false