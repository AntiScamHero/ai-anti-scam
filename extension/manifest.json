{
  "manifest_version": 3,
  "name": "AI 防詐盾牌",
  "short_name": "防詐盾牌",
  "description": "針對長輩日常詐騙情境設計的 AI 防詐助理，支援 AI 查詐騙、家庭守護、證據快照與高風險提醒。",
  "version": "6.3.2",
  "version_name": "6.3.2 接收端修正版",
  "action": {
    "default_title": "AI 防詐盾牌",
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "assets/images/warning-new.png",
      "32": "assets/images/warning-new.png",
      "48": "assets/images/warning-new.png",
      "128": "assets/images/warning-new.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "pages/welcome.html",
  "icons": {
    "16": "assets/images/warning-new.png",
    "32": "assets/images/warning-new.png",
    "48": "assets/images/warning-new.png",
    "128": "assets/images/warning-new.png"
  },
  "permissions": [
    "activeTab",
    "notifications",
    "scripting",
    "storage",
    "tabs",
    "offscreen"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/welcome.html",
        "pages/dashboard.html",
        "pages/simulator.html",
        "pages/line_share.html",
        "pages/blocked.html",
        "assets/images/*",
        "assets/audio/*",
        "assets/videos/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/config.js",
        "core/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}